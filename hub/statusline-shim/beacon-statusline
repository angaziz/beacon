#!/usr/bin/env bash
# Beacon statusline shim (P2, D6). Taps Claude Code's statusline JSON: forwards it to the hub (so the
# hub gets live Claude usage rate_limits + context/tokens -- docs/research §2.2), then DELEGATES to your
# real statusline renderer passed as args, so your status line is unchanged. No tokens involved;
# localhost only; never blocks the render.
#
# Configure in ~/.claude/settings.json (wraps your existing renderer):
#   "statusLine": { "type": "command",
#     "command": "/abs/path/hub/statusline-shim/beacon-statusline bash /Users/you/.claude/statusline-command.sh" }
# With no args it prints a minimal line.

input="$(cat)"

# Forward to the hub if it is running. Fixed port 8765 (ClaudeCodeBridge), with the port file as a
# fallback. Fire-and-forget, 1s cap, so a stopped hub never delays your prompt.
port="$(cat "$HOME/.beacon-hub/port" 2>/dev/null || echo 8765)"
curl -s -m 1 -X POST "http://127.0.0.1:${port}/statusline" \
  -H 'Content-Type: application/json' --data-binary "$input" >/dev/null 2>&1 &

if [ "$#" -gt 0 ]; then
  printf '%s' "$input" | "$@"        # delegate to your real renderer (same JSON on its stdin)
else
  model="$(printf '%s' "$input" | /usr/bin/python3 -c 'import sys,json
try:
    print(json.load(sys.stdin).get("model",{}).get("display_name","claude"))
except Exception:
    print("claude")' 2>/dev/null)"
  printf '%s' "${model:-claude}"
fi
