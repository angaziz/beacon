#!/usr/bin/env bash
# Beacon session-capture shim (Phase 2a, issue #110). Fires on CC SessionStart (command hook):
# reads env for terminal/editor identity, forwards to hub so it can later focus the session.
# Exits 0 always -- never blocks Claude Code.

input="$(</dev/stdin)"

# jq is a hard dep of the installer (it does the settings.json merge). Without it we cannot build
# valid JSON, so skip the POST entirely rather than send a malformed body the hub would drop.
command -v jq >/dev/null 2>&1 || exit 0

session_id="$(printf '%s' "$input" | jq -r '.session_id // ""' 2>/dev/null)"
cwd="$(printf '%s' "$input" | jq -r '.cwd // ""' 2>/dev/null)"

# WARP_FOCUS_URL may be absent; map to empty string so the field is always present.
host_app="${TERM_PROGRAM:-}"
focus_url="${WARP_FOCUS_URL:-}"
bundle_id="${__CFBundleIdentifier:-}"

# Build the payload with jq so a cwd/focus_url containing `"` or `\` is escaped (a printf-built
# string would be invalid JSON and the POST would be silently dropped).
payload="$(jq -n \
  --arg session_id "$session_id" --arg cwd "$cwd" --arg host_app "$host_app" \
  --arg focus_url "$focus_url" --arg bundle_id "$bundle_id" \
  '{session_id:$session_id,cwd:$cwd,host_app:$host_app,focus_url:$focus_url,bundle_id:$bundle_id}')"

# POST to the hub if it is running. Fixed port 8765, port file as fallback (same pattern as
# beacon-statusline). Fire-and-forget, 1s cap -- a stopped hub must never stall CC startup.
port=8765
[ -r "$HOME/.beacon-hub/port" ] && read -r port < "$HOME/.beacon-hub/port"
curl -s -m 1 -X POST "http://127.0.0.1:${port}/session" \
  -H 'Content-Type: application/json' --data-binary "$payload" >/dev/null 2>&1 &

exit 0
